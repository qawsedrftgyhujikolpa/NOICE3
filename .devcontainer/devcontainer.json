{
  "name": "NOICE - The Digital Void",
  "image": "mcr.microsoft.com/devcontainers/dotnet:8.0",
  "features": {},
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ffmpeg && mkdir -p uploads processed_videos",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "NOICE Server",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp"
      ],
      "settings": {
        "dotnet.defaultSolution": "NoiceServer/NoiceServer.csproj"
      }
    }
  }
}
